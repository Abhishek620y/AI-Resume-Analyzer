# --- Database ---
# SQLite for now. To switch to Postgres later, replace with:
# DATABASE_URL=postgresql://user:password@localhost:5432/resume_analyzer
DATABASE_URL=sqlite:///./database/app.db

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI provider (leave both blank to run in mock mode) ---
AI_PROVIDER=mock          # options: mock | openai | gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- File storage ---
UPLOAD_DIR=../uploads
MAX_UPLOAD_SIZE_MB=10
